{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mycroftai.org/schemas/johnny-johnny/backlog-v1.schema.json",
  "title": "Johnny-Johnny Backlog YAML v1",
  "description": "Machine-owned canonical backlog schema for Johnny-Johnny. Semantic identity is provider-neutral; provider-specific IDs are isolated under provider_metadata.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "project", "epics"],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "project": {
      "$ref": "#/$defs/project"
    },
    "epics": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/epic"
      },
      "default": []
    }
  },
  "$defs": {
    "stableId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "stringList": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "nullableString": {
      "type": ["string", "null"]
    },
    "providerMetadata": {
      "type": "object",
      "additionalProperties": true,
      "default": {}
    },
    "acceptanceCriteria": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/nonEmptyString"
      },
      "default": []
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider", "title", "provider_metadata"],
      "properties": {
        "provider": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "number": {
          "type": ["integer", "null"]
        },
        "url": {
          "$ref": "#/$defs/nullableString"
        },
        "provider_metadata": {
          "$ref": "#/$defs/providerMetadata"
        }
      }
    },
    "epic": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "type",
        "title",
        "repository",
        "status",
        "order",
        "description",
        "acceptance_criteria",
        "labels",
        "assignees",
        "milestone",
        "provider_metadata",
        "issues"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/stableId"
        },
        "type": {
          "type": "string",
          "const": "epic"
        },
        "title": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "repository": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "status": {
          "type": "string"
        },
        "order": {
          "type": "integer",
          "minimum": 0
        },
        "description": {
          "type": "string"
        },
        "acceptance_criteria": {
          "$ref": "#/$defs/acceptanceCriteria"
        },
        "labels": {
          "$ref": "#/$defs/stringList"
        },
        "assignees": {
          "$ref": "#/$defs/stringList"
        },
        "milestone": {
          "$ref": "#/$defs/nullableString"
        },
        "provider_metadata": {
          "$ref": "#/$defs/providerMetadata"
        },
        "issues": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/issue"
          },
          "default": []
        }
      }
    },
    "issue": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "type",
        "title",
        "repository",
        "status",
        "order",
        "description",
        "acceptance_criteria",
        "labels",
        "assignees",
        "milestone",
        "provider_metadata"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/stableId"
        },
        "type": {
          "type": "string",
          "const": "issue"
        },
        "title": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "repository": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "status": {
          "type": "string"
        },
        "order": {
          "type": "integer",
          "minimum": 0
        },
        "description": {
          "type": "string"
        },
        "acceptance_criteria": {
          "$ref": "#/$defs/acceptanceCriteria"
        },
        "labels": {
          "$ref": "#/$defs/stringList"
        },
        "assignees": {
          "$ref": "#/$defs/stringList"
        },
        "milestone": {
          "$ref": "#/$defs/nullableString"
        },
        "provider_metadata": {
          "$ref": "#/$defs/providerMetadata"
        }
      }
    }
  }
}